<Window x:Class="LifeDeck.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LifeDeck Studio" Height="820" Width="1340"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource TopBar}" Padding="10">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="LifeDeck Studio" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="  v1.9" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="8,2,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="Neu" Click="NewProfile_Click" />
                    <Button Content="Speichern" Click="SaveProfile_Click" />
                    <Button Content="Laden" Click="LoadProfile_Click" />
                    <Button Content="Verbinden" Click="ConnectTablet_Click" />
                    <Button Content="An Tablet senden" Click="SendToTablet_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="285" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Panel}" Padding="10" CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Projekt-Explorer" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <TextBlock Text="Assets" FontWeight="Bold" Margin="0,4,0,6" />
                        <Border Background="#15171A" BorderBrush="#333842" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Icons" Foreground="{StaticResource Muted}" />
                                <TextBlock Text="Sounds / Fonts / Animationen später" Foreground="{StaticResource Muted}" FontSize="11" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Settings" FontWeight="Bold" Margin="0,4,0,6" />
                        <TextBlock Text="Core eingefroren · Plugins erweitern LifeDeck ab jetzt modular." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,0" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Pages" FontWeight="Bold" Margin="0,0,0,6" />
                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="+" Width="38" MinWidth="38" Click="AddPage_Click" />
                            <Button Content="Umbenennen" Width="116" MinWidth="116" Click="RenamePage_Click" />
                            <Button Content="Duplizieren" Width="106" MinWidth="106" Click="DuplicatePage_Click" />
                            <Button Content="Löschen" Width="80" MinWidth="80" Click="DeletePage_Click" />
                        </WrapPanel>
                        <ListBox x:Name="PagesList" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionChanged="PagesList_SelectionChanged" Height="310" />

                        <TextBlock Text="Plugins" FontWeight="Bold" Margin="0,12,0,6" />
                        <ListBox x:Name="PluginList" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="135" SelectionChanged="PluginList_SelectionChanged" />
                        <TextBlock Text="Plugins liefern Actions, Events und States. Reaktionen werden im Normalmodus oder Node-Canvas definiert." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource Panel}" Padding="14" CornerRadius="8" Margin="10,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock x:Name="PreviewTitle" Text="Vorschau" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock x:Name="ConnectionStatus" Text="  · Tablet: nicht verbunden" Foreground="{StaticResource Muted}" VerticalAlignment="Center" />
                    </StackPanel>
                    <UniformGrid x:Name="ButtonGrid" Rows="3" Columns="4" />
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource Panel}" Padding="12" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Eigenschaften" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

                        <TabControl Background="{StaticResource Panel}" BorderBrush="#333842">
                            <TabItem Header="Button">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Button-Titel" />
                                    <TextBox x:Name="ButtonTitleBox" TextChanged="ButtonProperty_Changed" />

                                    <TextBlock Text="Untertitel" />
                                    <TextBox x:Name="ButtonSubtitleBox" TextChanged="ButtonProperty_Changed" />

                                    <TextBlock Text="Anzeige" />
                                    <ComboBox x:Name="DisplayModeBox" SelectionChanged="ButtonProperty_Changed" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Bild + Text" Tag="imageText" />
                                        <ComboBoxItem Content="Nur Bild" Tag="image" />
                                        <ComboBoxItem Content="Nur Text" Tag="text" />
                                    </ComboBox>

                                    <TextBlock Text="Farbe" />
                                    <DockPanel Margin="0,4,0,10">
                                        <Button DockPanel.Dock="Right" Content="Palette" Margin="6,0,0,0" Click="PickButtonColor_Click" />
                                        <TextBox x:Name="ButtonColorBox" Margin="0" TextChanged="ButtonProperty_Changed" />
                                    </DockPanel>

                                    <TextBlock Text="Icon (PNG/JPG)" />
                                    <DockPanel Margin="0,4,0,10">
                                        <Button DockPanel.Dock="Right" Content="..." Width="38" Margin="6,0,0,0" Click="PickIcon_Click" />
                                        <TextBox x:Name="IconPathBox" Margin="0" TextChanged="ButtonProperty_Changed" />
                                    </DockPanel>
                                    <Border Background="#15171A" BorderBrush="#333842" BorderThickness="1" CornerRadius="6" Height="92" Margin="0,0,0,10">
                                        <Grid>
                                            <TextBlock Text="Keine Icon-Vorschau" x:Name="NoIconPreviewText" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Muted}" />
                                            <Image x:Name="IconPreview" Stretch="Uniform" Margin="8" />
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Addon / Plugin" />
                                    <ComboBox x:Name="PluginBox" SelectionChanged="ButtonProperty_Changed" DisplayMemberPath="DisplayName" />

                                    <TextBlock Text="Aktion" />
                                    <ComboBox x:Name="ActionBox" SelectionChanged="ButtonProperty_Changed" DisplayMemberPath="DisplayName" />

                                    <TextBlock Text="Wert / Parameter" />
                                    <DockPanel>
                                        <Button x:Name="ActionValueBrowseButton" DockPanel.Dock="Right" Content="..." Width="38" Margin="6,0,0,0" Visibility="Collapsed" Click="PickActionValue_Click" />
                                        <ComboBox x:Name="ActionValueBox" IsEditable="False" SelectionChanged="ButtonProperty_Changed" />
                                    </DockPanel>
                                    <TextBox x:Name="ActionCustomValueBox" Visibility="Collapsed" TextChanged="ButtonProperty_Changed" />
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Plugins">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Plugin-Verwaltung" FontWeight="Bold" />
                                    <TextBlock Text="Wähle links ein Plugin aus. Hier siehst du Aktionen, Events und Plugin-spezifische Einstellungen." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,4,0,10" />

                                    <TextBlock Text="Ausgewähltes Plugin" />
                                    <TextBlock x:Name="SelectedPluginNameText" Text="-" FontSize="15" FontWeight="Bold" Margin="0,4,0,10" />

                                    <TextBlock Text="Aktionen" />
                                    <ListBox x:Name="PluginActionsList" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="90" Margin="0,4,0,10" />

                                    <TextBlock Text="Events / Zustände" />
                                    <ListBox x:Name="PluginEventsList" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="90" Margin="0,4,0,10" />

                                    <Border Background="#15171A" BorderBrush="#333842" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,6,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Plugin-Einstellungen" FontWeight="Bold" />
                                            <TextBlock Text="Diese Felder werden automatisch aus dem ausgewählten Plugin erzeugt. Neue Plugin-Settings erscheinen hier ohne Änderungen am Studio-Core." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,4,0,10" />
                                            <StackPanel x:Name="PluginSettingsPanel" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Normalmodus">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Einfache Status-Regeln" FontWeight="Bold" />
                                    <TextBlock Text="Für normale Nutzung: Wenn ein Plugin-Event einen Wert hat, ändere Text, Farbe oder Icon des Buttons." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,4,0,10" />

                                    <ListBox x:Name="RulesList" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="115" SelectionChanged="RulesList_SelectionChanged" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,12">
                                        <Button Content="Regel +" Click="AddRule_Click" />
                                        <Button Content="Regel löschen" Click="DeleteRule_Click" />
                                    </StackPanel>

                                    <TextBlock Text="Quelle / Plugin" />
                                    <ComboBox x:Name="RulePluginBox" SelectionChanged="RuleProperty_Changed" DisplayMemberPath="DisplayName" />

                                    <TextBlock Text="Event / Zustand" />
                                    <ComboBox x:Name="RuleEventBox" SelectionChanged="RuleProperty_Changed" DisplayMemberPath="DisplayName" />

                                    <TextBlock Text="Wenn Wert ist" />
                                    <ComboBox x:Name="RuleExpectedValueBox" IsEditable="False" SelectionChanged="RuleProperty_Changed" />
                                    <TextBox x:Name="RuleCustomExpectedValueBox" Visibility="Collapsed" TextChanged="RuleProperty_Changed" />

                                    <TextBlock Text="Dann Titel" />
                                    <TextBox x:Name="RuleTitleBox" TextChanged="RuleProperty_Changed" />

                                    <TextBlock Text="Dann Untertitel" />
                                    <TextBox x:Name="RuleSubtitleBox" TextChanged="RuleProperty_Changed" />

                                    <TextBlock Text="Dann Farbe" />
                                    <DockPanel Margin="0,4,0,10">
                                        <Button DockPanel.Dock="Right" Content="Palette" Margin="6,0,0,0" Click="PickRuleColor_Click" />
                                        <TextBox x:Name="RuleColorBox" Margin="0" TextChanged="RuleProperty_Changed" />
                                    </DockPanel>

                                    <TextBlock Text="Dann Icon" />
                                    <DockPanel Margin="0,4,0,10">
                                        <Button DockPanel.Dock="Right" Content="..." Width="38" Margin="6,0,0,0" Click="PickRuleIcon_Click" />
                                        <TextBox x:Name="RuleIconBox" Margin="0" TextChanged="RuleProperty_Changed" />
                                    </DockPanel>
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Erweiterte Nodes">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Erweiterter Node-Modus" FontWeight="Bold" />
                                    <TextBlock Text="Power-User-Ansicht für dieselbe Logik wie im Normalmodus: Event → Condition → Button-Änderung. Der Canvas ist ab v1.0 Teil des Cores; spätere Plugins fügen nur neue Events, States und Actions hinzu." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,4,0,8" />

                                    <Border Background="#111317" BorderBrush="#333842" BorderThickness="1" CornerRadius="6" Padding="0" Height="250" Margin="0,0,0,10">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                            <Canvas x:Name="NodeCanvas" Width="720" Height="230" Background="#111317" />
                                        </ScrollViewer>
                                    </Border>

                                    <Border Background="#15171A" BorderBrush="#333842" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Node-Aufbau" FontWeight="Bold" />
                                            <TextBlock Text="1. Event: Plugin-Zustand oder Plugin-Ereignis, z.B. OBS.RecordingChanged" TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,4,0,0" />
                                            <TextBlock Text="2. Condition: Operator + erwarteter Wert, z.B. == true oder contains Gaming" TextWrapping="Wrap" Foreground="{StaticResource Muted}" />
                                            <TextBlock Text="3. Action: Button visuell ändern, später auch Plugin-Aktionen, Sounds, Seitenwechsel und Chains." TextWrapping="Wrap" Foreground="{StaticResource Muted}" />
                                        </StackPanel>
                                    </Border>

                                    <ListBox x:Name="NodesList" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="95" SelectionChanged="NodesList_SelectionChanged" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,12">
                                        <Button Content="Node +" Click="AddNode_Click" />
                                        <Button Content="Node löschen" Click="DeleteNode_Click" />
                                    </StackPanel>

                                    <TextBlock Text="Name" />
                                    <TextBox x:Name="NodeNameBox" TextChanged="NodeProperty_Changed" />

                                    <TextBlock Text="Trigger Plugin" />
                                    <ComboBox x:Name="NodePluginBox" SelectionChanged="NodeProperty_Changed" DisplayMemberPath="DisplayName" />

                                    <TextBlock Text="Trigger Event" />
                                    <ComboBox x:Name="NodeEventBox" SelectionChanged="NodeProperty_Changed" DisplayMemberPath="DisplayName" />

                                    <TextBlock Text="Operator" />
                                    <ComboBox x:Name="NodeOperatorBox" SelectionChanged="NodeProperty_Changed">
                                        <ComboBoxItem Content="==" />
                                        <ComboBoxItem Content="!=" />
                                        <ComboBoxItem Content="&gt;" />
                                        <ComboBoxItem Content="&lt;" />
                                        <ComboBoxItem Content="contains" />
                                    </ComboBox>

                                    <TextBlock Text="Wert" />
                                    <ComboBox x:Name="NodeValueBox" IsEditable="False" SelectionChanged="NodeProperty_Changed" />
                                    <TextBox x:Name="NodeCustomValueBox" Visibility="Collapsed" TextChanged="NodeProperty_Changed" />

                                    <TextBlock Text="Button-Änderung" FontWeight="Bold" Margin="0,10,0,4" />
                                    <TextBox x:Name="NodeApplyTextBox" TextChanged="NodeProperty_Changed" />
                                    <DockPanel Margin="0,4,0,10">
                                        <Button DockPanel.Dock="Right" Content="Palette" Margin="6,0,0,0" Click="PickNodeColor_Click" />
                                        <TextBox x:Name="NodeApplyColorBox" Margin="0" TextChanged="NodeProperty_Changed" />
                                    </DockPanel>
                                    <TextBox x:Name="NodeApplyIconBox" TextChanged="NodeProperty_Changed" />
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
